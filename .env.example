# ============================================================
# AI Receptionist Backend – Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# Server
PORT=3001

# -------------------------------------------------------
# Google Calendar (Service Account)
# 1. Create a Google Cloud project
# 2. Enable the Google Calendar API
# 3. Create a Service Account and download the JSON key
# 4. Share your Google Calendar with the service account email
# 5. Fill in the values below
# -------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# -------------------------------------------------------
# Supabase
# Create a project at https://supabase.com
# Run src/db/schema.sql in the Supabase SQL editor first
# -------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------------------
# Business Settings
# -------------------------------------------------------
BUSINESS_NAME=Amityville Acupuncture

# Self-ping to prevent Render free-tier cold starts (set to your backend URL)
# SELF_PING_URL=https://amityville-ai-receptionist.onrender.com
BUSINESS_PHONE=+1 (631) 555-0000
BUSINESS_ADDRESS=Amityville, NY
BUSINESS_WEBSITE=https://www.amityvillewellness.com
TIMEZONE=America/New_York
DEFAULT_APPOINTMENT_DURATION=60
